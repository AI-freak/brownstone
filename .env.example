# Brownstone — environment configuration
# -----------------------------------------------------------------------------
# Load with Node 20.6+ via `node --env-file=.env`, or with `npm run` scripts
# in this repo which do the same. Don't commit a populated copy to git.

# --- Workspace & data ---------------------------------------------------------
BROWNSTONE_WORKSPACE=.
BROWNSTONE_DATA_DIR=.brownstone-platform

# --- Permission mode ----------------------------------------------------------
# read-only | workspace-write | danger-full-access
BROWNSTONE_MODE=read-only
BROWNSTONE_ENABLE_SHELL=false
BROWNSTONE_REQUIRE_APPROVALS=true
BROWNSTONE_REQUIRE_EXTERNAL_APPROVALS=true
# A long random string used as the second factor on any destructive action.
# Generate with `openssl rand -hex 32`. Never paste into the browser if you
# can avoid it — only enter it in the approval bar when actually approving.
BROWNSTONE_APPROVAL_TOKEN=

# --- Multi-user auth ----------------------------------------------------------
# Required in production. At least 32 characters. Used to sign session cookies
# and derive CSRF tokens. If unset in dev, a random secret is generated per
# process boot (cookies don't survive restarts).
BROWNSTONE_AUTH_SECRET=
BROWNSTONE_AUTH_COOKIE=__sa_session
BROWNSTONE_SESSION_TTL_MS=604800000     # 7 days
BROWNSTONE_BCRYPT_ROUNDS=12
BROWNSTONE_ALLOW_REGISTRATION=true
# Set to true behind a TLS-terminating reverse proxy so the auth cookie
# carries the Secure attribute.
BROWNSTONE_COOKIES_SECURE=false

# --- Provider -----------------------------------------------------------------
BROWNSTONE_MODEL=gpt-4.1-mini
BROWNSTONE_PROVIDER_MODE=
OPENAI_API_KEY=
OPENAI_BASE_URL=https://api.openai.com/v1

# --- HTTP topology ------------------------------------------------------------
BROWNSTONE_SERVER_HOST=127.0.0.1
BROWNSTONE_SERVER_PORT=8787
BROWNSTONE_CONTROL_PLANE_URL=http://127.0.0.1:8787
BROWNSTONE_CONTROL_PLANE_TOKEN=

BROWNSTONE_BROWSER_HOST=127.0.0.1
BROWNSTONE_BROWSER_PORT=8788

BROWNSTONE_WEB_HOST=127.0.0.1
BROWNSTONE_WEB_PORT=8791

# --- Browser worker -----------------------------------------------------------
# Comma-separated list of hostnames the browser is allowed to navigate to.
BROWNSTONE_BROWSER_ALLOWLIST=
BROWNSTONE_MAX_BROWSER_ACTIONS=3

# --- Task processing ----------------------------------------------------------
BROWNSTONE_TASK_POLL_MS=1500
BROWNSTONE_MAX_TOOL_STEPS=4
BROWNSTONE_MAX_TASK_RUNTIME_MS=90000

# --- Search & research --------------------------------------------------------
BROWNSTONE_SEARCH_PROVIDER=
BRAVE_SEARCH_API_KEY=
BROWNSTONE_MAX_SEARCH_RESULTS=5
BROWNSTONE_MAX_FETCHED_PAGES=3

# --- Uploads / plugins --------------------------------------------------------
BROWNSTONE_UPLOAD_MAX_BYTES=1048576       # 1 MiB
BROWNSTONE_PLUGIN_APPROVAL=manual

# --- Misc ---------------------------------------------------------------------
BROWNSTONE_THINKING_MODE=balanced
BROWNSTONE_SCHEDULER_TICK_MS=30000        # How often the scheduler worker checks for due tasks
